{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "server", "--", "--env-file=../.env"],
      "port": 3001,
      "autoPort": true,
      "cwd": "family-dashboard"
    },
    {
      "name": "Vite Client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "client"],
      "port": 5173,
      "autoPort": true,
      "cwd": "family-dashboard"
    },
    {
      "name": "Both (concurrently)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true,
      "cwd": "family-dashboard"
    }
  ]
}
