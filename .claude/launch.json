{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite Client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "client", "--", "--port", "6010", "--strictPort"],
      "port": 6010,
      "autoPort": false
    },
    {
      "name": "Both (concurrently)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 6010,
      "autoPort": true
    },
    {
      "name": "API Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "server", "--", "--env-file=../.env"],
      "port": 4000,
      "autoPort": true
    }
  ]
}
