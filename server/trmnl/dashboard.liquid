{% comment %}
  FamilyDash -> TRMNL dashboard markup (TRMNL X, landscape, 16-gray).

  Inline styles only (no style block, no CSS grid). The outer 3x2 grid is a TABLE
  (table-layout:fixed) -- robust on TRMNL's renderer and immune to the framework
  .layout flex/justify-content rules that wrapped a flexbox grid raggedly. Each
  cell fills full height: avatar + first name, tickets (left) + money (right), a
  4-across flex row of conic-gradient progress rings (chores + task sets, 8 max),
  and a latest-activity line pinned to the bottom. Last row padded with empties.

  NOTE: literal glyphs are written as HTML numeric entities (&#127903; etc.) so the
  source stays pure ASCII -- avatar/task emoji come from the data, not the markup.

  Data (server/src/services/trmnlService.js, kept under TRMNL's 2KB webhook cap):
    { family_name, users: [ { name, emoji, initial, is_parent, money,
      money_negative, tickets, tiles:[{emoji,pct}], latest } ] }
{% endcomment %}

<div class="layout" style="height:100%;">
  <table style="width:100%;height:100%;border-collapse:collapse;table-layout:fixed;border:2px solid #000;">
    <tr>
    {% for u in users %}
      <td style="width:33.33%;border:1px solid #000;padding:0;vertical-align:top;">
        <div style="display:flex;flex-direction:column;height:100%;box-sizing:border-box;padding:10px 12px;">

        <div style="display:flex;align-items:center;gap:8px;">
          <div style="width:48px;height:48px;flex:0 0 48px;border:2px solid #000;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;line-height:1;">{% if u.emoji and u.emoji != '' %}{{ u.emoji }}{% else %}{{ u.initial }}{% endif %}</div>
          <span style="flex:1 1 auto;min-width:0;font-size:24px;font-weight:bold;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ u.name | split: ' ' | first }}{% if u.is_parent %} <span style="font-size:13px;font-weight:normal;color:#5a5a5a;">grown-up</span>{% endif %}</span>
          <div style="flex:0 0 auto;text-align:right;font-size:18px;font-weight:bold;line-height:1.25;">
            <div>{{ u.tickets }} &#127903;</div>
            <div{% if u.money_negative %} style="color:#555;text-decoration:line-through;"{% endif %}>{{ u.money }}</div>
          </div>
        </div>

        {% if u.tiles.size > 0 %}
          <div style="display:flex;flex-wrap:wrap;margin-top:12px;">
            {% for t in u.tiles %}
              <div style="width:33.33%;box-sizing:border-box;display:flex;justify-content:center;margin-bottom:10px;">
                <div style="width:62px;height:62px;border-radius:50%;background:conic-gradient(#000 {{ t.pct }}%, #cfcfcf 0);display:flex;align-items:center;justify-content:center;">
                  <div style="width:48px;height:48px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:26px;line-height:1;overflow:hidden;">{% if t.img %}<img class="image" src="https://dash.straychips.com/api/uploads/badges/{{ t.img }}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;display:block;">{% elsif t.pct == 100 %}&#10003;{% else %}{{ t.emoji }}{% endif %}</div>
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div style="margin-top:8px;color:#666;font-size:15px;">All clear &#10024;</div>
        {% endif %}

        <div style="margin-top:auto;padding-top:10px;border-top:1px dotted #aaa;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;{% if u.latest == '' %}color:#999;{% endif %}">{% if u.latest != '' %}{{ u.latest | truncate: 48 }}{% else %}&mdash;{% endif %}</div>

        </div>
      </td>
      {% assign m = forloop.index | modulo: 3 %}
      {% if m == 0 and forloop.last == false %}</tr><tr>{% endif %}
    {% endfor %}
    {% assign rem = users.size | modulo: 3 %}
    {% if rem > 0 %}
      {% assign pad = 3 | minus: rem %}
      {% for i in (1..pad) %}<td style="width:33.33%;border:1px solid #000;"></td>{% endfor %}
    {% endif %}
    </tr>
  </table>
</div>

<div class="title_bar">
  <img class="image" src="https://trmnl.com/images/plugins/trmnl--render.svg">
  <span class="title">{{ family_name }}</span>
  <span class="instance">Tasks &amp; money</span>
</div>
